# Drekee AI 1.5 Pro - Environment Variables
# Copy this file to .env and fill with your API keys

# Main reasoning model (LLaMA 3.3 70B)
GROQ_API_KEY_1=your_groq_api_key_here

# Image analysis model (LLaMA 4 Scout)
GROQ_API_KEY_2=your_second_groq_api_key_here

# Connector routing analysis model (LLaMA 3.1 8B Instant)
GROQ_ANALISE_API_KEY=your_groq_analysis_api_key_here

# Recovery orchestration agent (LLaMA 3.1 8B Instant)
GROQ_AGENT_API_KEY=your_groq_agent_api_key_here

# Response review and validation (OpenRouter - Qwen 2.5 Plus)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_API_KEY_2=your_second_openrouter_api_key_here

# Web search for context (Tavily)
TAVILY_API_KEY=your_tavily_api_key_here

# Optional: Computational knowledge engine
WOLFRAM_APP_ID=your_wolfram_app_id_here

# Optional: Port for local development
PORT=3000
